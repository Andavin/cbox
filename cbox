#!/usr/bin/env bash
set -euo pipefail

if [[ -z "${1:-}" ]]; then
  echo "Usage: cbox <profile> [args...]" >&2
  exit 1
fi

if [[ "$1" == "profiles" ]]; then
  # NOTE: || true prevents grep exiting the script (set -e) when no matches are found
  profiles=$(docker images --format '{{.Repository}}' | grep '^cbox-' | sed 's/^cbox-//' | sort -u || true)
  if [[ -z "$profiles" ]]; then
    echo "No profiles available" >&2
  else
    echo "$profiles"
  fi
  exit 0
fi

image="cbox-$1"
shift

path="/workspace/$(pwd)"

# Extract GitHub token via git's credential system (works with any helper:
# store, osxkeychain, manager/manager-core, etc.)
GH_TOKEN=""
GH_TOKEN=$(printf 'protocol=https\nhost=github.com\n' | git credential fill 2>/dev/null | sed -n 's/^password=//p') || true

# Write credentials to a temp file for git inside the container
GIT_CREDS_FILE=$(mktemp)
trap 'rm -f "$GIT_CREDS_FILE"' EXIT
if [[ -n "$GH_TOKEN" ]]; then
  GH_USER=$(printf 'protocol=https\nhost=github.com\n' | git credential fill 2>/dev/null | sed -n 's/^username=//p') || true
  echo "https://${GH_USER:-git}:${GH_TOKEN}@github.com" > "$GIT_CREDS_FILE"
fi

docker run -it --init --rm \
  -u 0:0 \
  -w "$path" \
  -v "$(pwd)":"$path" \
  $([ -d node_modules ] && echo "-v $path/node_modules") \
  -v claude_config:/claude-config \
  -v ~/.gitconfig:/root/.gitconfig:ro \
  -v "$GIT_CREDS_FILE":/root/.git-credentials:ro \
  -e CLAUDE_CONFIG_DIR=/claude-config \
  -e IS_SANDBOX=1 \
  ${GH_TOKEN:+-e GH_TOKEN="$GH_TOKEN"} \
  "$image" "$@"
